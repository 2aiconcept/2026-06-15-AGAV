{
  "name": "mini-crm",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "generators": {
    "@schematics/angular:component": {
      "changeDetection": "OnPush"
    }
  },
  "sourceRoot": "apps/mini-crm/src",
  "prefix": "app",
  "tags": ["type:app", "scope:app"],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "options": {
        "browser": "apps/mini-crm/src/main.ts",
        "polyfills": [], //  zoneless : on n'inclut plus zone.js

        "tsConfig": "apps/mini-crm/tsconfig.app.json",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/mini-crm/public"
          }
        ],
        "styles": ["apps/mini-crm/src/styles.css", "bootstrap/dist/css/bootstrap.min.css"],
        "outputPath": "dist/mini-crm"
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "1MB",
              "maximumError": "2MB"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kB",
              "maximumError": "8kB"
            }
          ],
          "outputHashing": "all",
          "fileReplacements": [
            {
              "replace": "apps/mini-crm/src/environments/environment.ts",
              "with": "apps/mini-crm/src/environments/environment.prod.ts"
            }
          ]
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production",
      "outputs": ["{options.outputPath}"]
    },
    "serve": {
      "executor": "@angular/build:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "mini-crm:build:production"
        },
        "development": {
          "buildTarget": "mini-crm:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "test": {
      "executor": "@angular/build:unit-test"
    }
  }
}
